# Única porta exposta no host. Mude aqui para trocar a porta de acesso ao sistema.
APP_PORT=8080

# Banco de dados (uso interno entre containers — nunca exposto)
POSTGRES_USER=sparapan
POSTGRES_PASSWORD=troque_esta_senha
POSTGRES_DB=sparapan

# Auth.js — gere com: openssl rand -base64 32
AUTH_SECRET=

# Usuário admin criado pelo seed (npm run db:seed)
SEED_ADMIN_EMAIL=admin@sparapan.com.br
SEED_ADMIN_PASSWORD=troque_esta_senha

# E-mail: MAIL_PROVIDER = smtp | resend
MAIL_PROVIDER=smtp
# smtp: em dev, aponta para o container mailpit (docker compose --profile dev up).
#       em produção, use o SMTP da sua caixa de e-mail (host/porta/usuário reais).
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM=naosresponda@sparapan.com.br
# resend: preencha se MAIL_PROVIDER=resend
RESEND_API_KEY=

# Upload de arquivos — sempre local, nunca S3/serviço externo
STORAGE_DRIVER=local

# Mapa (NORMAM-303 — coordenadas de obras): tiles remotos gratuitos sem chave.
# Trocar por um tileserver self-hosted no futuro é só mudar esta URL.
MAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty

# URL pública do sistema, como o usuário acessa no navegador.
# Em produção use o domínio/IP real (ex.: https://sparapan.com.br ou
# http://SEU_IP:PORTA) — é usado nos links de portal/assinatura e no
# webhook do Mercado Pago. Se ficar vazia, o login ainda funciona (o
# host é inferido da requisição), mas os links públicos saem errados.
AUTH_URL=http://localhost:8080

# LMS — checkout de matérias via Mercado Pago (Checkout Pro).
# Use o access token de TESTE da sua conta MP enquanto valida o fluxo.
MERCADOPAGO_ACCESS_TOKEN=
